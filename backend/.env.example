APP_NAME=NeuroLearn API
APP_ENV=development
DEBUG=true

# Preferred configuration: DB_* values (single source of truth)
DB_HOST=127.0.0.1
DB_PORT=55432
DB_NAME=neurolearn
DB_USER=neurolearn
DB_PASSWORD=neurolearn

# Optional full override (takes precedence if set)
